# Django
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Outbound mail (SMTP)
# ---------------------------------------------------------------------------
# When DJANGO_DEBUG=1 the default backend is the console backend, so the
# fields below can be left blank for local development.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=Application Test Platform <noreply@localhost>
# Optional Message-ID domain. Useful for production deployments so all
# outbound Message-IDs share a consistent right-hand side.
MAIL_MESSAGE_ID_DOMAIN=

# ---------------------------------------------------------------------------
# Inbound mail (IMAP) — used by `python manage.py fetch_mail`
# ---------------------------------------------------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=1
IMAP_MAILBOX=INBOX
